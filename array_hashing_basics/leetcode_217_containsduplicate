//space complexity:-o(1);
//not it's just not efficient for large inputs.


class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        for(int i =0;i<nums.size();i++)
        {
            for(int j=i+1;j<nums.size();j++)
            {
                if (nums[i]==nums[j])
                return true;
            }
        }
        return false;
        
    }
};

