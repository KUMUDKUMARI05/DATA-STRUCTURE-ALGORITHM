// Brute+optimal+mysolution: since by moving forwrd length would definately decrease so,as compansionate 
/* Gap:why did we keep on comapring the height left and right!!??
We move the pointer at the smaller height in hope of finding a taller
 height that can compensate for the decreasing width.*/



class Solution {
public:
    int maxArea(vector<int>& height) {
        int left=0;int right=height.size()-1;
        int area=0;

        
        while(left<right)
        {
           
           area=max(area,(min(height[right],height[left]))*(right-left));
           if(height[left]>height[right])
           right--;
           else
           left++;
        }
        return area;

    }
};